{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Workspace package resolution (@agent-ui/* -> package src) */
    "paths": {
      "@agent-ui/components": ["./packages/agent-ui/components/src/index.ts"],
      "@agent-ui/components/*": ["./packages/agent-ui/components/src/*"],
      "@agent-ui/shared": ["./packages/agent-ui/shared/src/index.ts"],
      "@agent-ui/shared/*": ["./packages/agent-ui/shared/src/*"],
      "@agent-ui/a2ui": ["./packages/agent-ui/a2ui/src/index.ts"],
      "@agent-ui/a2ui/*": ["./packages/agent-ui/a2ui/src/*"],
      "@agent-ui/a2a": ["./packages/agent-ui/a2a/src/index.ts"],
      "@agent-ui/a2a/*": ["./packages/agent-ui/a2a/src/*"],
      "@agent-ui/icons": ["./packages/agent-ui/icons/src/index.ts"],
      "@agent-ui/icons/*": ["./packages/agent-ui/icons/src/*"],
      "@agent-ui/app": ["./packages/agent-ui/app/src/index.ts"],
      "@agent-ui/app/*": ["./packages/agent-ui/app/src/*"],
      "@agent-ui/router": ["./packages/agent-ui/router/src/index.ts"],
      "@agent-ui/router/*": ["./packages/agent-ui/router/src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["packages/agent-ui/*/src"]
}
