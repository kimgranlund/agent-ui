{
  "name": "@agent-ui/app",
  "description": "App-surface compositions for the agent-ui family: application shells, a settings surface, a conversation (chat) surface with an inline generative-UI canvas, and the agent-admin workbench that ties them together.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./app-shell": "./src/controls/app-shell/app-shell.ts",
    "./super-shell": "./src/controls/super-shell/super-shell.ts",
    "./super-shell.css": "./src/controls/super-shell/super-shell.css",
    "./app-shell.css": "./src/controls/app-shell/app-shell.css",
    "./master-detail": "./src/controls/master-detail/master-detail.ts",
    "./master-detail.css": "./src/controls/master-detail/master-detail.css",
    "./master-detail-pane": "./src/controls/master-detail/master-detail-pane.ts",
    "./master-detail-pane.css": "./src/controls/master-detail/master-detail-pane.css",
    "./nav-rail": "./src/controls/nav-rail/nav-rail.ts",
    "./nav-rail.css": "./src/controls/nav-rail/nav-rail.css",
    "./settings": "./src/controls/settings/settings.ts",
    "./settings.css": "./src/controls/settings/settings.css",
    "./settings-schema": "./src/controls/settings/schema.ts",
    "./settings-store": "./src/controls/settings/store.ts",
    "./settings-memory-store": "./src/controls/settings/memory-store.ts",
    "./surface-host": "./src/controls/surface-host/surface-host.ts",
    "./surface-host.css": "./src/controls/surface-host/surface-host.css",
    "./conversation": "./src/controls/conversation/conversation.ts",
    "./conversation.css": "./src/controls/conversation/conversation.css",
    "./conversation-composer": "./src/controls/conversation/conversation-composer.ts",
    "./conversation-composer.css": "./src/controls/conversation/conversation-composer.css",
    "./composer-options": "./src/controls/conversation/composer-options.ts",
    "./agent-admin": "./src/controls/agent-admin/agent-admin.ts",
    "./agent-admin.css": "./src/controls/agent-admin/agent-admin.css",
    "./agent-admin-schema": "./src/controls/agent-admin/agent-admin-schema.ts"
  },
  "dependencies": {
    "@agent-ui/components": "*",
    "@agent-ui/a2ui": "*",
    "@agent-ui/shared": "*",
    "@agent-ui/code": "*"
