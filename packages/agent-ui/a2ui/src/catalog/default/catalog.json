                                     "type": { "type": "string", "enum": ["string", "number"] } },
                     "required": ["key", "label"] } }, "bindable": true, "mapsTo": "columns" },
        "rows": { "type": { "type": "array", "items": { "type": "object" } }, "bindable": true, "mapsTo": "rows" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" }
