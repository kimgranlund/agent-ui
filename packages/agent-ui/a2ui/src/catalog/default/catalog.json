{
  "catalogId": "agent-ui",
  "protocolVersion": "v1.0",
  "components": {
    "Text": {
      "properties": {
        "text": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "variant": { "type": { "type": "string", "enum": ["h1", "h2", "h3", "h4", "h5", "caption", "body"] }, "mapsTo": "variant" }
      }
    },

    "Button": {
      "properties": {
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "variant": { "type": { "type": "string" }, "mapsTo": "variant" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "action": {
          "type": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "context": { "type": "object" },
              "wantResponse": { "type": "boolean" }
            },
            "required": ["action"]
          },
          "mapsTo": "action"
        }
      }
    },

    "TextField": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" },
        "placeholder": { "type": { "type": "string" }, "bindable": true, "mapsTo": "placeholder" },
        "size": { "type": { "type": "string", "enum": ["sm", "md", "lg"] }, "mapsTo": "size" },
        "readonly": { "type": { "type": "boolean" }, "mapsTo": "readonly" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "type": { "type": { "type": "string", "enum": ["text", "email", "url", "tel", "password", "search", "number", "currency", "unit", "percent", "date", "time"] }, "mapsTo": "type" },
        "currency": { "type": { "type": "string" }, "mapsTo": "currency" },
        "unit": { "type": { "type": "string" }, "mapsTo": "unit" },
        "step": { "type": { "type": "number" }, "mapsTo": "step" },
        "min": { "type": { "type": "string" }, "mapsTo": "min" },
        "max": { "type": { "type": "string" }, "mapsTo": "max" }
      },
      "value": { "prop": "value", "event": "change" }
    },

    "Field": {
      "properties": {
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" },
        "description": { "type": { "type": "string" }, "bindable": true, "mapsTo": "description" }
      },
      "children": "child"
    },

    "FormProvider": {
      "properties": {},
      "children": "ChildList"
    },

    "Checkbox": {
      "properties": {
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" },
        "label": { "type": { "type": "string" }, "mapsTo": "textContent" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "checked", "event": "change" }
    },

    "Switch": {
      "properties": {
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" },
        "label": { "type": { "type": "string" }, "mapsTo": "textContent" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "checked", "event": "change" }
    },

    "Select": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "placeholder": { "type": { "type": "string" }, "mapsTo": "placeholder" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "value", "event": "select" },
      "children": "ChildList"
    },

    "Option": {
      "properties": {
        "value": { "type": { "type": "string" }, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" }
      }
    },

    "Row": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "align": { "type": { "type": "string", "enum": ["start", "center", "end", "stretch", "baseline"] }, "mapsTo": "align" },
        "justify": { "type": { "type": "string", "enum": ["start", "center", "end", "between", "around", "evenly"] }, "mapsTo": "justify" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "wrap": { "type": { "type": "boolean" }, "mapsTo": "wrap" }
      },
      "children": "ChildList"
    },

    "Column": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "align": { "type": { "type": "string", "enum": ["start", "center", "end", "stretch", "baseline"] }, "mapsTo": "align" },
        "justify": { "type": { "type": "string", "enum": ["start", "center", "end", "between", "around", "evenly"] }, "mapsTo": "justify" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "wrap": { "type": { "type": "boolean" }, "mapsTo": "wrap" }
      },
      "children": "ChildList"
    },

    "Card": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" }
      },
      "children": "ChildList"
    },

    "CardHeader": {
      "properties": {},
      "children": "ChildList"
    },

    "CardContent": {
      "properties": {
        "scrollable": { "type": { "type": "boolean" }, "mapsTo": "scrollable" }
      },
      "children": "ChildList"
    },

    "CardFooter": {
      "properties": {},
      "children": "ChildList"
    },

    "Tabs": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "selected": { "type": { "type": ["string", "number"] }, "bindable": true, "mapsTo": "selected" }
      },
      "value": { "prop": "selected", "event": "select" },
      "children": "ChildList"
    },

    "Tab": {
      "properties": {},
      "children": "ChildList"
    },

    "TabPanel": {
      "properties": {},
      "children": "ChildList"
    },

    "Modal": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "open": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "open" },
        "persistent": { "type": { "type": "boolean" }, "mapsTo": "persistent" }
      },
      "value": { "prop": "open", "event": "toggle" },
      "children": "ChildList"
    }
  },

  "functions": {
    "required": {
      "callableFrom": "clientOnly",
      "args": { "value": { "type": ["string", "null"] } },
      "returns": { "type": "object" }
    },
    "email": {
      "callableFrom": "clientOnly",
      "args": { "value": { "type": "string" } },
      "returns": { "type": "object" }
    },
    "regex": {
      "callableFrom": "clientOnly",
      "args": { "value": { "type": "string" }, "pattern": { "type": "string" } },
      "returns": { "type": "object" }
    },
    "ping": {
      "callableFrom": "clientOrRemote",
      "args": {},
      "returns": { "type": "boolean" }
    }
  }
}
