{
  "catalogId": "agent-ui",
  "protocolVersion": "v1.0",
  "components": {
    "Text": {
      "properties": {
        "text": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "variant": { "type": { "type": "string", "enum": ["h1", "h2", "h3", "h4", "h5", "caption", "body"] }, "mapsTo": "variant" },
        "truncate": { "type": { "type": "boolean" }, "mapsTo": "truncate" },
        "emphasis": { "type": { "type": "boolean" }, "mapsTo": "emphasis" },
        "href": { "type": { "type": "string" }, "bindable": true, "mapsTo": "href", "format": "safe-href" }
      }
    },

    "Button": {
      "properties": {
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "variant": { "type": { "type": "string", "enum": ["solid", "soft", "ghost"] }, "mapsTo": "variant" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "action": {
          "type": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "context": { "type": "object" },
              "wantResponse": { "type": "boolean" }
            },
            "required": ["action"]
          },
          "mapsTo": "action"
        }
      }
    },

    "TextField": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" },
        "placeholder": { "type": { "type": "string" }, "bindable": true, "mapsTo": "placeholder" },
        "size": { "type": { "type": "string", "enum": ["sm", "md", "lg"] }, "mapsTo": "size" },
        "readonly": { "type": { "type": "boolean" }, "mapsTo": "readonly" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "type": { "type": { "type": "string", "enum": ["text", "email", "url", "tel", "password", "search", "number", "currency", "unit", "percent", "date", "time"] }, "mapsTo": "type" },
        "currency": { "type": { "type": "string" }, "mapsTo": "currency" },
        "unit": { "type": { "type": "string" }, "mapsTo": "unit" },
        "step": { "type": { "type": "number" }, "mapsTo": "step" },
        "min": { "type": { "type": "string" }, "mapsTo": "min" },
        "max": { "type": { "type": "string" }, "mapsTo": "max" }
      },
      "value": { "prop": "value", "event": "change" }
    },

    "Field": {
      "properties": {
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" },
        "description": { "type": { "type": "string" }, "bindable": true, "mapsTo": "description" }
      },
      "children": "child"
    },

    "FormProvider": {
      "properties": {},
      "children": "ChildList"
    },

    "Checkbox": {
      "properties": {
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" },
        "label": { "type": { "type": "string" }, "mapsTo": "textContent" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "checked", "event": "change" }
    },

    "Switch": {
      "properties": {
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" },
        "label": { "type": { "type": "string" }, "mapsTo": "textContent" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "checked", "event": "change" }
    },

    "Select": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "placeholder": { "type": { "type": "string" }, "mapsTo": "placeholder" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" }
      },
      "value": { "prop": "value", "event": "select" },
      "children": "ChildList"
    },

    "Option": {
      "properties": {
        "value": { "type": { "type": "string" }, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" }
      }
    },

    "Row": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "align": { "type": { "type": "string", "enum": ["start", "center", "end", "stretch", "baseline"] }, "mapsTo": "align" },
        "justify": { "type": { "type": "string", "enum": ["start", "center", "end", "between", "around", "evenly"] }, "mapsTo": "justify" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "wrap": { "type": { "type": "boolean" }, "mapsTo": "wrap" },
        "reflow": { "type": { "type": "string", "enum": ["auto", "locked"] }, "mapsTo": "reflow" }
      },
      "children": "ChildList"
    },

    "Column": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "align": { "type": { "type": "string", "enum": ["stretch", "start", "end", "baseline"] }, "mapsTo": "align" },
        "justify": { "type": { "type": "string", "enum": ["start", "center", "end", "between", "around", "evenly"] }, "mapsTo": "justify" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "wrap": { "type": { "type": "boolean" }, "mapsTo": "wrap" },
        "reflow": { "type": { "type": "string", "enum": ["locked", "auto"] }, "mapsTo": "reflow" }
      },
      "children": "ChildList"
    },

    "Card": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" }
      },
      "children": "ChildList"
    },

    "CardHeader": {
      "properties": {},
      "children": "ChildList"
    },

    "CardContent": {
      "properties": {
        "scrollable": { "type": { "type": "boolean" }, "mapsTo": "scrollable" }
      },
      "children": "ChildList"
    },

    "CardFooter": {
      "properties": {},
      "children": "ChildList"
    },

    "Tabs": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "selected": { "type": { "type": ["string", "number"] }, "bindable": true, "mapsTo": "selected" }
      },
      "value": { "prop": "selected", "event": "select" },
      "children": "ChildList"
    },

    "Tab": {
      "properties": {},
      "children": "ChildList"
    },

    "TabPanel": {
      "properties": {},
      "children": "ChildList"
    },

    "Modal": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "open": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "open" },
        "persistent": { "type": { "type": "boolean" }, "mapsTo": "persistent" }
      },
      "value": { "prop": "open", "event": "toggle" },
      "children": "ChildList"
    },

    "Icon": {
      "properties": {
        "name": { "type": { "type": "string" }, "bindable": true, "mapsTo": "name" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" }
      }
    },

    "Menu": {
      "properties": {
        "open": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "open" },
        "placement": { "type": { "type": "string", "enum": ["bottom-start", "bottom-end", "top-start", "top-end", "left-start", "left-end", "right-start", "right-end"] }, "mapsTo": "placement" }
      },
      "value": { "prop": "open", "event": "toggle" },
      "children": "ChildList"
    },

    "MenuItem": {
      "properties": {
        "value": { "type": { "type": "string" }, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" }
      }
    },

    "Popover": {
      "properties": {
        "open": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "open" },
        "placement": { "type": { "type": "string", "enum": ["bottom-start", "bottom-end", "top-start", "top-end", "left-start", "left-end", "right-start", "right-end"] }, "mapsTo": "placement" }
      },
      "value": { "prop": "open", "event": "toggle" },
      "children": "ChildList"
    },

    "Tooltip": {
      "properties": {
        "open": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "open" },
        "placement": { "type": { "type": "string", "enum": ["bottom-start", "bottom-end", "top-start", "top-end", "left-start", "left-end", "right-start", "right-end"] }, "mapsTo": "placement" },
        "delay": { "type": { "type": "number" }, "mapsTo": "delay" }
      },
      "value": { "prop": "open", "event": "toggle" },
      "children": "ChildList"
    },

    "RadioGroup": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "orientation": { "type": { "type": "string", "enum": ["horizontal", "vertical"] }, "mapsTo": "orientation" }
      },
      "value": { "prop": "value", "event": "change" },
      "children": "ChildList"
    },

    "Radio": {
      "properties": {
        "value": { "type": { "type": "string" }, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" }
      }
    },

    "SegmentedControl": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "orientation": { "type": { "type": "string", "enum": ["horizontal", "vertical"] }, "mapsTo": "orientation" }
      },
      "value": { "prop": "value", "event": "change" },
      "children": "ChildList"
    },

    "Segment": {
      "properties": {
        "value": { "type": { "type": "string" }, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "textContent" },
        "checked": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "checked" }
      }
    },

    "Slider": {
      "properties": {
        "value": { "type": { "type": "number" }, "bindable": true, "mapsTo": "value" },
        "min": { "type": { "type": "number" }, "mapsTo": "min" },
        "max": { "type": { "type": "number" }, "mapsTo": "max" },
        "step": { "type": { "type": "number" }, "mapsTo": "step" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" }
      },
      "value": { "prop": "value", "event": "change" }
    },

    "SliderMulti": {
      "properties": {
        "min": { "type": { "type": "number" }, "mapsTo": "min" },
        "max": { "type": { "type": "number" }, "mapsTo": "max" },
        "step": { "type": { "type": "number" }, "mapsTo": "step" },
        "valueLo": { "type": { "type": "number" }, "bindable": true, "mapsTo": "valueLo" },
        "valueHi": { "type": { "type": "number" }, "bindable": true, "mapsTo": "valueHi" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" }
      }
    },

    "Calendar": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "min": { "type": { "type": "string" }, "mapsTo": "min" },
        "max": { "type": { "type": "string" }, "mapsTo": "max" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "required": { "type": { "type": "boolean" }, "mapsTo": "required" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" },
        "mode": { "type": { "type": "string", "enum": ["single", "range"] }, "mapsTo": "mode" },
        "valueStart": { "type": { "type": "string" }, "bindable": true, "mapsTo": "valueStart" },
        "valueEnd": { "type": { "type": "string" }, "bindable": true, "mapsTo": "valueEnd" }
      },
      "value": { "prop": "value", "event": "change" }
    },

    "ComboBox": {
      "properties": {
        "value": { "type": { "type": "string" }, "bindable": true, "mapsTo": "value" },
        "label": { "type": { "type": "string" }, "bindable": true, "mapsTo": "label" },
        "placeholder": { "type": { "type": "string" }, "mapsTo": "placeholder" },
        "strict": { "type": { "type": "boolean" }, "mapsTo": "strict" },
        "name": { "type": { "type": "string" }, "mapsTo": "name" },
        "disabled": { "type": { "type": "boolean" }, "bindable": true, "mapsTo": "disabled" }
      },
      "value": { "prop": "value", "event": "change" },
      "children": "ChildList"
    },

    "List": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "align": { "type": { "type": "string", "enum": ["start", "center", "end", "stretch", "baseline"] }, "mapsTo": "align" },
        "justify": { "type": { "type": "string", "enum": ["start", "center", "end", "between", "around", "evenly"] }, "mapsTo": "justify" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "wrap": { "type": { "type": "boolean" }, "mapsTo": "wrap" }
      },
      "children": "ChildList"
    },

    "Grid": {
      "properties": {
        "elevation": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "elevation" },
        "brightness": { "type": { "type": "string", "enum": ["-3", "-2", "-1", "0", "1", "2", "3"] }, "mapsTo": "brightness" },
        "gap": { "type": { "type": "string", "enum": ["none", "xs", "sm", "md", "lg", "xl", "2xl"] }, "mapsTo": "gap" },
        "min": { "type": { "type": "string" }, "mapsTo": "min" }
      },
      "children": "ChildList"
    },

    "Split": {
      "properties": {
        "axis": { "type": { "type": "string", "enum": ["horizontal", "vertical"] }, "mapsTo": "axis" },
        "sizes": { "type": { "type": "array", "items": { "type": "number" } }, "bindable": true, "mapsTo": "sizes" }
      },
      "value": { "prop": "sizes", "event": "change" },
      "children": "ChildList"
    },

    "SplitPane": {
      "properties": {
        "initial": { "type": { "type": "number" }, "mapsTo": "initial" },
        "min": { "type": { "type": "string" }, "mapsTo": "min" },
        "max": { "type": { "type": "string" }, "mapsTo": "max" },
        "collapsible": { "type": { "type": "boolean" }, "mapsTo": "collapsible" }
      },
      "children": "ChildList"
    },

    "Sparkline": {
