{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(python3 scripts/adr_ratify.py:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bundle-size-reminder.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/css-comment-guard.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/adr-status-guard.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-freshness-guard.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "adia-ui": {
      "source": {
        "source": "github",
        "repo": "adiahealth/gen-ui-kit",
        "path": "packages/plugins/.claude-plugin/marketplace.json",
        "sparsePaths": ["packages/plugins"]
      }
    }
  },
  "enabledPlugins": {
    "llm@nonoun-plugins": true,
    "harness@nonoun-plugins": true,
    "docs@nonoun-plugins": true,
    "teamwork@nonoun-plugins": true,
    "screens@nonoun-plugins": true,
    "agent-protocols@nonoun-plugins": true,
    "design@nonoun-plugins": true,
    "figma@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true
  }
}
